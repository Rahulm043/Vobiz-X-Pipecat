# Vobiz + Pipecat AI Voice Agent - Environment Configuration
# Copy this file to .env and fill in your actual values

# OpenAI API Key (for LLM)
OPENAI_API_KEY=sk-...

# Sarvam API Key (for STT and TTS)
SARVAM_API_KEY=...

# Vobiz Telephony Credentials
VOBIZ_AUTH_ID=MA_XXXXXXXX
VOBIZ_AUTH_TOKEN=your-token-here
VOBIZ_PHONE_NUMBER=+91XXXXXXXXXX

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server Configuration
PUBLIC_URL=https://your-domain.com
ENV=production

# Optional: Transfer agent phone number
TRANSFER_AGENT_NUMBER=+91XXXXXXXXXX

# Optional: Agent and Organization names (for Pipecat Cloud)
AGENT_NAME=your-agent-name
ORGANIZATION_NAME=your-org-name
